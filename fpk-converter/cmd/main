#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
APP_DIR="${TRIM_PKG}/app/code"
VENV_PYTHON="${APP_DIR}/venv/bin/python"
WEB_SERVER="${APP_DIR}/web_server.py"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

ensure_dirs() {
    if [ ! -d "${TRIM_PKGVAR}" ]; then
        mkdir -p "${TRIM_PKGVAR}"
    fi
    if [ ! -d "${APP_DIR}" ]; then
        log_msg "FATAL: APP_DIR missing: ${APP_DIR}"
        return 1
    fi
    if [ ! -x "${VENV_PYTHON}" ]; then
        log_msg "FATAL: venv python not found: ${VENV_PYTHON}"
        return 1
    fi
    if [ ! -f "${WEB_SERVER}" ]; then
        log_msg "FATAL: web_server.py not found: ${WEB_SERVER}"
        return 1
    fi
    return 0
}

start_process() {
    if status; then
        return 0
    fi

    ensure_dirs || return 1

    log_msg "Starting process ..."
    log_msg "APP_DIR = ${APP_DIR}"
    log_msg "VENV_PYTHON = ${VENV_PYTHON}"

    # Start web server in background; redirect all IO to log
    cd "${APP_DIR}"
    nohup "${VENV_PYTHON}" "${WEB_SERVER}" >> "${LOG_FILE}" 2>&1 &
    local pid=$!
    printf "%s" "${pid}" > "${PID_FILE}"
    log_msg "Started web server, pid = ${pid}"

    # Wait briefly to catch immediate startup failure
    sleep 1
    if ! check_process "${pid}"; then
        log_msg "ERROR: web server died immediately after start. Check ${LOG_FILE}"
        rm -f "${PID_FILE}"
        return 1
    fi
    return 0
}

stop_process() {
    log_msg "Stopping process ..."

    if [ -r "${PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

        log_msg "pid=${pid}"
        if ! check_process "${pid}"; then
            rm -f "${PID_FILE}"
            log_msg "remove pid file 1"
            return
        fi

        # Send TERM, then escalate to KILL if needed
        log_msg "send TERM signal to PID:${pid}..."
        kill -TERM "${pid}" >> "${LOG_FILE}" 2>&1

        local count=0
        while check_process "${pid}" && [ ${count} -lt 10 ]; do
            sleep 1
            count=$((count + 1))
            log_msg "waiting process terminal... (${count}s/10s)"
        done

        if check_process "${pid}"; then
            log_msg "send KILL signal to PID:${pid}..."
            kill -KILL "${pid}" 2>/dev/null
            sleep 1
            # Also kill any child processes
            pkill -KILL -P "${pid}" 2>/dev/null
            rm -f "${PID_FILE}"
        else
            log_msg "process killed... "
            rm -f "${PID_FILE}"
        fi
    fi

    return 0
}

check_process() {
    local pid=$1
    if [ -z "${pid}" ]; then
        return 1
    fi
    if kill -0 "${pid}" 2>/dev/null; then
        return 0  # process exist
    else
        return 1  # process not exist
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            # Process is not running but pidfile exists - clean it up
            rm -f "${PID_FILE}"
        fi
    fi

    return 1
}

case "$1" in
start)
    # exit 0 if success, exit 1 if failed
    start_process
    exit $?
    ;;
stop)
    # exit 0 if success, exit 1 if failed
    stop_process
    exit $?
    ;;
status)
    # exit 0 if running, exit 3 if not running
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
