#!/bin/sh

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"

mkdir -p "${TRIM_PKGVAR}" 2>/dev/null || true

APP_DIR="${TRIM_PKG}/app/fpkconverter"
PKG="${APP_DIR}/packages"
WEB="${APP_DIR}/web_server.py"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE} 2>/dev/null || true
}

CMD="cd ${APP_DIR} && PYTHONPATH=${PKG}:\${PYTHONPATH} python3 ${WEB}"

start_process() {
    if status_impl; then
        return 0
    fi

    log_msg "Starting ..."
    bash -c "${CMD}" >> ${LOG_FILE} 2>&1 &
    _pid=$!
    printf "%s" "${_pid}" > ${PID_FILE}
    log_msg "PID=${_pid}"
    return 0
}

stop_process() {
    log_msg "Stopping ..."

    if [ -r "${PID_FILE}" ]; then
        _pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

        if ! check_process "${_pid}"; then
            rm -f "${PID_FILE}"
            return 0
        fi

        log_msg "send TERM to PID:${_pid}"
        kill -TERM ${_pid} >> ${LOG_FILE} 2>&1

        _count=0
        while check_process "${_pid}" && [ ${_count} -lt 10 ]; do
            sleep 1
            _count=$((_count + 1))
        done

        if check_process "${_pid}"; then
            log_msg "send KILL to PID:${_pid}"
            kill -KILL "${_pid}"
            sleep 1
        fi
        rm -f "${PID_FILE}"
    fi

    return 0
}

check_process() {
    _pid=$1
    kill -0 "${_pid}" 2>/dev/null && return 0 || return 1
}

status_impl() {
    if [ -f "${PID_FILE}" ]; then
        _pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${_pid}"; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi
    fi
    return 1
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status_impl; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac