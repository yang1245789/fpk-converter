#!/bin/bash
# 飞牛应用启动/停止/状态脚本
# 参照论坛 node_exporter 成功案例

APP_DIR="${TRIM_PKG}/app/fpkconverter"
PKG_DIR="${APP_DIR}/packages"
WEB_SERVER="${APP_DIR}/web_server.py"
LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"

mkdir -p "${TRIM_PKGVAR}"

log_msg() {
    echo -e "$(date +'%Y/%m/%d %H:%M:%S')\t$*" >> "${LOG_FILE}"
}

check_process() {
    local pid=$1
    kill -0 "${pid}" 2>/dev/null && return 0 || return 1
}

find_process() {
    ps -fe | grep 'web_server\.py' | grep -v grep | grep -v tail | wc -l
}

case $1 in
start)
    processNum=$(find_process)
    if [ "${processNum}" -ne 0 ]; then
        log_msg "Already running"
        exit 0
    fi

    if [ ! -f "${WEB_SERVER}" ]; then
        log_msg "ERROR: ${WEB_SERVER} not found"
        exit 1
    fi

    if [ ! -d "${PKG_DIR}" ]; then
        log_msg "ERROR: packages dir not found"
        exit 1
    fi

    cd "${APP_DIR}"
    export PYTHONPATH="${PKG_DIR}:${PYTHONPATH}"
    log_msg "Starting with PYTHONPATH=${PKG_DIR}"

    nohup python3 "${WEB_SERVER}" >> "${LOG_FILE}" 2>&1 &
    RETVAL=$?

    if [ ${RETVAL} -eq 0 ]; then
        echo "$!" > "${PID_FILE}"
        log_msg "Started ok, pid=$!"
        exit 0
    else
        log_msg "Start failed"
        exit 1
    fi
    ;;

stop)
    log_msg "Stopping..."
    if [ -f "${PID_FILE}" ]; then
        pid=$(cat "${PID_FILE}")
        if check_process "${pid}"; then
            kill -TERM "${pid}" 2>/dev/null
            local c=0
            while check_process "${pid}" && [ $c -lt 10 ]; do
                sleep 1; c=$((c+1))
            done
            check_process "${pid}" && kill -KILL "${pid}" 2>/dev/null
        fi
        rm -f "${PID_FILE}"
    fi
    # 兜底：确保没有残留进程
    pkill -f 'web_server\.py' 2>/dev/null
    exit 0
    ;;

status)
    processNum=$(find_process)
    if [ "${processNum}" -ne 0 ]; then
        exit 0
    else
        rm -f "${PID_FILE}"
        exit 3
    fi
    ;;

*)
    exit 1
    ;;
esac