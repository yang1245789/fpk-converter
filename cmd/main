#!/bin/sh

# === 路径定位（修复: fnpack去掉了app/前缀） ===
# TRIM_PKG=/var/apps/fpkconverter (root) 或 /vol1/@appcenter/fpkconverter (data)
# 实际结构: ${TRIM_PKG}/fpkconverter/web_server.py

if [ -n "${TRIM_PKG}" ]; then
    APP_DIR="${TRIM_PKG}/fpkconverter"
else
    APP_DIR="$(cd "$(dirname "$0")" && pwd)/../fpkconverter"
fi

# 兜底: /var/apps/fpkconverter/fpkconverter
[ ! -f "$APP_DIR/web_server.py" ] && APP_DIR="/var/apps/fpkconverter/fpkconverter"
# 再兜底: /vol1/@appcenter/fpkconverter/fpkconverter
[ ! -f "$APP_DIR/web_server.py" ] && APP_DIR="/vol1/@appcenter/fpkconverter/fpkconverter"

# 数据目录
[ -n "${TRIM_PKGVAR}" ] && VAR_DIR="${TRIM_PKGVAR}" || VAR_DIR="$APP_DIR/data"
mkdir -p "$VAR_DIR" 2>/dev/null || true

PID_FILE="$VAR_DIR/app.pid"
LOG_FILE="$VAR_DIR/app.log"

# 调试日志
echo "$(date) $1 APP=$APP_DIR VAR=$VAR_DIR PKG=${TRIM_PKG:-none} PKGVAR=${TRIM_PKGVAR:-none}" >> "$APP_DIR/boot.log" 2>/dev/null || true

check() {
    [ -f "$PID_FILE" ] || return 1
    _p=$(head -n1 "$PID_FILE" 2>/dev/null | tr -d '[:space:]')
    [ -n "$_p" ] && kill -0 "$_p" 2>/dev/null
}

case $1 in
start)
    check && exit 0
    [ -f "$APP_DIR/web_server.py" ] || { echo "FAIL web_server.py not found at $APP_DIR" >> "$APP_DIR/boot.log" 2>/dev/null; exit 1; }
    cd "$APP_DIR" || exit 1
    export PYTHONPATH="$APP_DIR/packages:$PYTHONPATH"
    python3 web_server.py >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    echo "OK PID=$!" >> "$APP_DIR/boot.log" 2>/dev/null || true
    exit 0
    ;;
stop)
    [ -f "$PID_FILE" ] && { _p=$(head -n1 "$PID_FILE" | tr -d '[:space:]'); kill -TERM "$_p" 2>/dev/null; sleep 1; kill -KILL "$_p" 2>/dev/null; rm -f "$PID_FILE"; }
    exit 0
    ;;
status)
    check && exit 0 || exit 3
    ;;
*)
    exit 1
    ;;
esac