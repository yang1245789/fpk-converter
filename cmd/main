#!/bin/sh
# v12 - 基于真实诊断日志修复
# 事实: TRIM_PKG为空, TRIM_PKGVAR=/vol1/@appdata/fpkconverter
# 策略: 用dirname $0定位, 不依赖TRIM_PKG

LOG="/vol1/@appdata/fpkconverter/info.log"
mkdir -p /vol1/@appdata/fpkconverter 2>/dev/null

echo "=== $(date) arg=$1 ===" >> "$LOG"
echo "TRIM_PKG=${TRIM_PKG:-EMPTY}" >> "$LOG"
echo "TRIM_PKGVAR=${TRIM_PKGVAR:-EMPTY}" >> "$LOG"
echo "SELF=$0" >> "$LOG"

# 用 $0 定位安装根目录
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
echo "SELF_DIR=$SELF_DIR" >> "$LOG"
echo "ls SELF_DIR:" >> "$LOG"
ls -la "$SELF_DIR/" >> "$LOG" 2>&1
echo "ls SELF_DIR/..:" >> "$LOG"
ls -la "$SELF_DIR/../" >> "$LOG" 2>&1

# 在安装根目录下找 web_server.py
APP_DIR=""
for d in "$SELF_DIR/../fpkconverter" \
         "$SELF_DIR/../app/fpkconverter" \
         "$SELF_DIR/../../fpkconverter" \
         "$SELF_DIR/../../app/fpkconverter"; do
    if [ -f "$d/web_server.py" ]; then
        APP_DIR="$d"
        break
    fi
done

# 兜底: 从 TRIM_PKGVAR 推测
if [ -z "$APP_DIR" ] && [ -n "${TRIM_PKGVAR}" ]; then
    BASE="$(dirname "$TRIM_PKGVAR")"
    for d in "$BASE/fpkconverter" "$BASE/app/fpkconverter"; do
        if [ -f "$d/web_server.py" ]; then
            APP_DIR="$d"
            break
        fi
    done
fi

echo "APP_DIR=${APP_DIR:-NOT_FOUND}" >> "$LOG"

if [ -n "$APP_DIR" ]; then
    echo "ls APP_DIR:" >> "$LOG"
    ls -la "$APP_DIR/" >> "$LOG" 2>&1
fi

VAR="${TRIM_PKGVAR:-/vol1/@appdata/fpkconverter}"
mkdir -p "$VAR" 2>/dev/null
PID="$VAR/app.pid"

check() {
    [ -f "$PID" ] || return 1
    p=$(head -n1 "$PID" 2>/dev/null | tr -d '[:space:]')
    [ -n "$p" ] && kill -0 "$p" 2>/dev/null
}

case $1 in
start)
    if check; then
        echo "already running" >> "$LOG"
        exit 0
    fi
    if [ -z "$APP_DIR" ] || [ ! -f "$APP_DIR/web_server.py" ]; then
        echo "FAIL: web_server.py not found" >> "$LOG"
        exit 1
    fi
    cd "$APP_DIR" || { echo "FAIL cd to $APP_DIR" >> "$LOG"; exit 1; }
    export PYTHONPATH="$APP_DIR/packages:$PYTHONPATH"
    echo "Starting: python3 $APP_DIR/web_server.py" >> "$LOG"
    python3 web_server.py >> "$VAR/app.log" 2>&1 &
    echo $! > "$PID"
    echo "Started PID=$!" >> "$LOG"
    exit 0
    ;;
stop)
    if [ -f "$PID" ]; then
        p=$(head -n1 "$PID" | tr -d '[:space:]')
        kill -TERM "$p" 2>/dev/null
        sleep 1
        kill -KILL "$p" 2>/dev/null
        rm -f "$PID"
    fi
    exit 0
    ;;
status)
    check && exit 0 || exit 3
    ;;
*)
    exit 1
    ;;
esac