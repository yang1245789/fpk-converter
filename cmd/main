#!/bin/sh
# 飞牛 cmd/main - install_type=root
# 安装路径: /var/apps/fpkconverter

APP="/var/apps/fpkconverter/app/fpkconverter/web_server.py"
DIR="/var/apps/fpkconverter/app/fpkconverter"

if [ "$1" = "start" ]; then
    [ -f "$APP" ] || exit 1
    cd "$DIR" || exit 1
    export PYTHONPATH="$DIR/packages:$PYTHONPATH"
    nohup python3 "$APP" > /dev/null 2>&1 &
    sleep 2
    ps -fe 2>/dev/null | grep -q '[w]eb_server\.py' && exit 0
    exit 1
elif [ "$1" = "stop" ]; then
    pkill -f 'web_server\.py' 2>/dev/null
    exit 0
elif [ "$1" = "status" ]; then
    ps -fe 2>/dev/null | grep -q '[w]eb_server\.py' && exit 0
    exit 3
fi
exit 1