#!/bin/sh
# v13 - 基于真实目录结构修复
# 事实: cmd在/var/apps/fpkconverter/, app在/vol2/@appcenter/fpkconverter/
# 通过 target 软链接找到 app 目录

LOG="/vol2/@appdata/fpkconverter/info.log"
mkdir -p /vol2/@appdata/fpkconverter 2>/dev/null

echo "=== $(date) arg=$1 ===" >> "$LOG"

# 定位安装根目录
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
echo "ROOT=$ROOT" >> "$LOG"

# 尝试 target 软链接
APP_DIR=""
if [ -L "$ROOT/target" ]; then
    TARGET="$(readlink "$ROOT/target")"
    echo "TARGET=$TARGET" >> "$LOG"
    for d in "$TARGET/fpkconverter" "$TARGET/app/fpkconverter"; do
        if [ -f "$d/web_server.py" ]; then
            APP_DIR="$d"
            break
        fi
    done
fi

# 回退: 直接在 ROOT 下找
if [ -z "$APP_DIR" ]; then
    for d in "$ROOT/fpkconverter" "$ROOT/app/fpkconverter"; do
        if [ -f "$d/web_server.py" ]; then
            APP_DIR="$d"
            break
        fi
    done
fi

# 回退: TRIM_PKGVAR 的父目录
if [ -z "$APP_DIR" ] && [ -n "${TRIM_PKGVAR}" ]; then
    BASE="$(dirname "$TRIM_PKGVAR")"
    for d in "$BASE/fpkconverter" "$BASE/app/fpkconverter"; do
        if [ -f "$d/web_server.py" ]; then
            APP_DIR="$d"
            break
        fi
    done
fi

echo "APP_DIR=${APP_DIR:-NOT_FOUND}" >> "$LOG"

if [ -n "$APP_DIR" ]; then
    echo "ls APP_DIR:" >> "$LOG"
    ls -la "$APP_DIR/" >> "$LOG" 2>&1
fi

VAR="${TRIM_PKGVAR:-/vol2/@appdata/fpkconverter}"
mkdir -p "$VAR" 2>/dev/null
PID="$VAR/app.pid"

check() {
    [ -f "$PID" ] || return 1
    p=$(head -n1 "$PID" 2>/dev/null | tr -d '[:space:]')
    [ -n "$p" ] && kill -0 "$p" 2>/dev/null
}

case $1 in
start)
    if check; then
        echo "already running" >> "$LOG"
        exit 0
    fi
    if [ -z "$APP_DIR" ] || [ ! -f "$APP_DIR/web_server.py" ]; then
        echo "FAIL: web_server.py not found" >> "$LOG"
        exit 1
    fi
    cd "$APP_DIR" || { echo "FAIL cd" >> "$LOG"; exit 1; }
    export PYTHONPATH="$APP_DIR/packages:$PYTHONPATH"
    echo "Starting python3 at $APP_DIR" >> "$LOG"
    python3 web_server.py >> "$VAR/app.log" 2>&1 &
    echo $! > "$PID"
    echo "Started PID=$!" >> "$LOG"
    exit 0
    ;;
stop)
    if [ -f "$PID" ]; then
        p=$(head -n1 "$PID" | tr -d '[:space:]')
        kill -TERM "$p" 2>/dev/null
        sleep 1
        kill -KILL "$p" 2>/dev/null
        rm -f "$PID"
    fi
    exit 0
    ;;
status)
    check && exit 0 || exit 3
    ;;
*)
    exit 1
    ;;
esac