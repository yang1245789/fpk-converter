#!/bin/bash
PACKAGE_BASE="${TRIM_APPDEST}"
[ -z "${PACKAGE_BASE}" ] && PACKAGE_BASE="${TRIM_PKG}"

APP_DIR="${PACKAGE_BASE}/app/fpkconverter"
WEB="${APP_DIR}/web_server.py"
PKG="${APP_DIR}/packages"
LOG="/var/log/fpkconverter.log"
mkdir -p "${TRIM_PKGVAR}"

case $1 in
start)
    processNum=$(ps -fe | grep 'web_server\.py' | grep -v grep | grep -v tail | wc -l)
    if [ "${processNum}" -ne 0 ]; then
        exit 0
    fi

    cd "${APP_DIR}"
    export PYTHONPATH="${PKG}:${PYTHONPATH}"

    nohup python3 "${WEB}" >> "${LOG}" 2>&1 &
    RETVAL=$?

    if [ ${RETVAL} -eq 0 ]; then
        exit 0
    else
        exit 1
    fi
    ;;

stop)
    pkill -f 'web_server\.py'
    exit 0
    ;;

status)
    processNum=$(ps -fe | grep 'web_server\.py' | grep -v grep | grep -v tail | wc -l)
    if [ "${processNum}" -ne 0 ]; then
        exit 0
    else
        exit 3
    fi
    ;;

*)
    exit 1
    ;;
esac