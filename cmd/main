#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"

APP_DIR="${TRIM_PKG}/app/fpkconverter"
CMD="cd ${APP_DIR} && export PYTHONPATH=${APP_DIR}/packages:${PYTHONPATH} && /usr/bin/python3 ${APP_DIR}/web_server.py"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

start_process() {
    if status; then
        return 0
    fi

    log_msg "Starting process ..."
    bash -c "${CMD}" >> ${LOG_FILE} 2>&1 &
    printf "%s" "$!" > ${PID_FILE}
    return 0
}

stop_process() {
    log_msg "Stopping process ..."

    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

        if ! check_process "${pid}"; then
            rm -f "${PID_FILE}"
            return
        fi

        log_msg "send TERM to PID:${pid}..."
        kill -TERM ${pid} >> ${LOG_FILE} 2>&1

        local count=0
        while check_process "${pid}" && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
        done

        if check_process "${pid}"; then
            log_msg "send KILL to PID:${pid}..."
            kill -KILL "${pid}"
            sleep 1
        fi
        rm -f "${PID_FILE}"
    fi

    return 0
}

check_process() {
    local pid=$1
    kill -0 "${pid}" 2>/dev/null && return 0 || return 1
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi
    fi

    return 1
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac