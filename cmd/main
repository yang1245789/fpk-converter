#!/bin/sh
# fpkconverter cmd/main v11
# 日志固定写入 /tmp/fpkconverter.log (tmpfs 一定存在)

LOG="/tmp/fpkconverter.log"
echo "=== $(date) arg=$1 ===" >> "$LOG"
echo "TRIM_PKG=${TRIM_PKG:-EMPTY}" >> "$LOG"
echo "TRIM_PKGVAR=${TRIM_PKGVAR:-EMPTY}" >> "$LOG"
echo "SELF=$0" >> "$LOG"

# 定位 APP_DIR
APP_DIR=""
if [ -n "${TRIM_PKG}" ] && [ -d "${TRIM_PKG}" ]; then
    # 尝试多种路径
    for d in "${TRIM_PKG}/fpkconverter" "${TRIM_PKG}/app/fpkconverter"; do
        if [ -f "$d/web_server.py" ]; then
            APP_DIR="$d"
            break
        fi
    done
fi

if [ -z "$APP_DIR" ]; then
    for d in /var/apps/fpkconverter/fpkconverter \
             /var/apps/fpkconverter/app/fpkconverter \
             /vol1/@appcenter/fpkconverter/fpkconverter \
             /vol1/@appcenter/fpkconverter/app/fpkconverter; do
        if [ -f "$d/web_server.py" ]; then
            APP_DIR="$d"
            break
        fi
    done
fi

echo "APP_DIR=${APP_DIR:-NOT_FOUND}" >> "$LOG"

# 数据目录
VAR="${TRIM_PKGVAR:-${APP_DIR:-/tmp}/data}"
mkdir -p "$VAR" 2>/dev/null
PID="$VAR/app.pid"

check() {
    [ -f "$PID" ] || return 1
    p=$(head -n1 "$PID" 2>/dev/null | tr -d '[:space:]')
    [ -n "$p" ] && kill -0 "$p" 2>/dev/null
}

case $1 in
start)
    if check; then
        echo "already running" >> "$LOG"
        exit 0
    fi
    if [ -z "$APP_DIR" ] || [ ! -f "$APP_DIR/web_server.py" ]; then
        echo "FAIL: web_server.py not found" >> "$LOG"
        echo "Listing TRIM_PKG:" >> "$LOG"
        ls -laR "${TRIM_PKG:-/dev/null}" 2>/dev/null >> "$LOG"
        exit 1
    fi
    echo "Starting python3 at $APP_DIR" >> "$LOG"
    cd "$APP_DIR" || { echo "FAIL cd" >> "$LOG"; exit 1; }
    export PYTHONPATH="$APP_DIR/packages:$PYTHONPATH"
    python3 web_server.py >> "$VAR/app.log" 2>&1 &
    echo $! > "$PID"
    echo "Started PID=$!" >> "$LOG"
    exit 0
    ;;
stop)
    if [ -f "$PID" ]; then
        p=$(head -n1 "$PID" | tr -d '[:space:]')
        kill -TERM "$p" 2>/dev/null
        sleep 1
        kill -KILL "$p" 2>/dev/null
        rm -f "$PID"
    fi
    exit 0
    ;;
status)
    check && exit 0 || exit 3
    ;;
*)
    exit 1
    ;;
esac